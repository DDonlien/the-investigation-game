      "effectHook": "environment.intelligence.multiPayCoerce",
      "status": "stub"
    },
    "yu-jia-zhi-zui": {
      "effectHook": "environment.truth.placeAtBottom",
      "status": "stub"
    },
    "*": {
      "effectHook": "pending.environment.effect",
      "status": "pending"
    }
  },
  "supportCards": {
